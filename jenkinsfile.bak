pipeline {
    agent any

    environment {
        EC2_USER    = 'ubuntu'
        EC2_IP      = '18.232.121.30' // <--- Cambia por la IP de tu EC2
        EC2_SSH     = "${EC2_USER}@${EC2_IP}"
        REPO_DIR    = '/home/ubuntu/python-project/python-flask-cicd-ec2' // <--- Ruta de tu proyecto en la EC2
    }

    stages {
        stage('Checkout') {
            steps {
                echo '========== CHECKOUT =========='
                git url: 'https://github.com/marcosolano21/python-flask-cicd-ec2.git', branch: 'main'
            }
            post {
                success {
                    echo 'Checkout completed successfully.'
                }

                failure {
                    echo 'Checkout failed.'
                }
            }
        }
        
        
        stage('Descargar Cambios en EC2') {
            steps {
                echo 'Conectando a la EC2 para descargar el último código de GitHub...'
                sshagent(credentials: ['ec2-ssh-pem']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_SSH} '
                            cd ${REPO_DIR}/
                            
                            # Traer los cambios de GitHub de forma limpia
                            git pull origin main
                            
                            # Asegurar que las dependencias de Python estén al día
                            source venv/bin/activate
                            #pip install -r flask/requirements.txt
                        '
                    """
                }
            }
        }

        stage('Desplegar Instancia 1 (Puerto 8081)') {
            steps {
                echo 'Reiniciando Instancia 1 con el código nuevo...'
                sshagent(credentials: ['ec2-ssh-pem']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_SSH} '
                            fuser -k 8081/tcp || true
                            cd ${REPO_DIR}/
                            source venv/bin/activate
                            nohup python3 app.py 8081 > flask_8081.log 2>&1 &
                            sleep 5
                        '
                    """
                }
            }
        }

        stage('Desplegar Instancia 2 (Puerto 8082)') {
            steps {
                echo 'Reiniciando Instancia 2 con el código nuevo...'
                sshagent(credentials: ['ec2-ssh-pem']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_SSH} '
                            fuser -k 8082/tcp || true
                            cd ${REPO_DIR}/
                            source venv/bin/activate
                            nohup python3 app.py 8082 > flask_8082.log 2>&1 &
                            sleep 5
                        '
                    """
                }
            }
        }
    }

    post {
        success { echo '¡Despliegue automático desde GitHub completado con éxito!' }
        failure { echo 'Error en el despliegue automático.' }
    }
}