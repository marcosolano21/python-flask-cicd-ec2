pipeline {
    agent any

    environment {
        EC2_USER    = 'ubuntu'
        EC2_IP      = '18.232.121.30' // <--- Cambia por tu IP
        EC2_SSH     = "${EC2_USER}@${EC2_IP}"
        REPO_DIR    = '/home/ubuntu/python-project/python-flask-cicd-ec2'
    }

    stages {
            stage('Checkout') {
                steps {
                    echo '========== CHECKOUT =========='
                    git url: 'https://github.com/marcosolano21/python-flask-cicd-ec2.git', branch: 'main'
                }
                post {
                    success {
                        echo 'Checkout completed successfully.'
                    }
    
                    failure {
                        echo 'Checkout failed.'
                    }
                }
        }
        // ==========================================
        // FASE DE INTEGRACIÓN CONTINUA (CI)
        // Corriendo localmente en el contenedor de Jenkins
        // ==========================================
        
        stage('Preparar Entorno Local') {
            steps {
                echo 'Instalando dependencias de prueba en el entorno de Jenkins...'
                // Creamos un entorno virtual temporal dentro del agente de Jenkins
                sh '''
                    python3 -m venv venv_local
                    . venv_local/bin/activate
                    pwd
                    ls -l
                    pip install -r requirements.txt
                '''
            }
        }

        stage('Análisis de Calidad (Linting)') {
            steps {
                echo 'Ejecutando Flake8 para validar estilo y sintaxis...'
                sh '''
                    . venv_local/bin/activate
                    # Falla si hay errores de sintaxis o variables no definidas
                    flake8 app.py --count --select=E9,F63,F7,F82 --show-source --statistics
                '''
            }
        }

        stage('Análisis de Seguridad (SAST)') {
            steps {
                echo 'Ejecutando Bandit para buscar fallos de seguridad en el código...'
                sh '''
                    . venv_local/bin/activate
                    bandit -r app.py
                '''
            }
        }

        stage('Pruebas Unitarias (Unit Tests)') {
            steps {
                echo 'Ejecutando pruebas con PyTest...'
                sh '''
                    . venv_local/bin/activate
                    #cd flask
                    PYTHONPATH=. pytest test_app.py -v
                '''
            }
        }

        // ==========================================
        // FASE DE DESPLIEGUE CONTINUO (CD)
        // Solo se ejecuta si todas las etapas de CI pasaron en verde
        // ==========================================

        stage('Descargar Cambios en EC2') {
            steps {
                echo 'CI Exitoso. Iniciando fase CD en la EC2...'
                sshagent(credentials: ['ec2-ssh-pem']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_SSH} '
                            cd ${REPO_DIR}
                            git pull origin main
                            source venv/bin/activate
                            pip install -r requirements.txt
                        '
                    """
                }
            }
        }

        stage('Desplegar Instancia 1 (Puerto 8081)') {
            steps {
                echo 'Reiniciando Instancia 1 (8081)...'
                sshagent(credentials: ['ec2-ssh-pem']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_SSH} '
                            fuser -k 8081/tcp || true
                            cd ${REPO_DIR}
                            source venv/bin/activate
                            nohup python3 app.py 8081 > flask_8081.log 2>&1 &
                            sleep 5
                        '
                    """
                }
            }
        }

        stage('Desplegar Instancia 2 (Puerto 8082)') {
            steps {
                echo 'Reiniciando Instancia 2 (8082)...'
                sshagent(credentials: ['ec2-ssh-pem']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_SSH} '
                            fuser -k 8082/tcp || true
                            cd ${REPO_DIR}/
                            source venv/bin/activate
                            nohup python3 app.py 8082 > flask_8082.log 2>&1 &
                            sleep 5
                        '
                    """
                }
            }
        }
        
        stage('Smoke Test (Producción)') {
            steps {
                echo "Validando que el balanceador Nginx y Flask respondan en http://${EC2_IP}..."
                sh """
                    # Hacemos una petición HTTP y guardamos solo el código de respuesta (ej: 200, 502, 404)
                    STATUS_CODE=\$(curl -s -o /dev/null -w "%{http_code}" http://${EC2_IP}/)
                    
                    echo "Respuesta del servidor: \$STATUS_CODE"
                    
                    if [ "\$STATUS_CODE" -eq 200 ]; then
                        echo "¡Prueba de humo aprobada exitosamente! El sitio está vivo."
                    else
                        echo "¡ALERTA! El servidor respondió con código \$STATUS_CODE. El despliegue falló."
                        exit 1
                    fi
                """
            }
        }
        
        
    }

    post {
        success {
            echo '¡El Pipeline completo de CI/CD terminó de manera exitosa!'
        }
        failure {
            echo 'El pipeline falló. Revisa la etapa que se pintó de rojo para solucionar el problema.'
        }
    }
}