pipeline {
    agent any

    environment {
        EC2_USER    = 'ubuntu'
        EC2_IP      = '18.232.121.30' // <--- Update your EC2´s public IP
        EC2_SSH     = "${EC2_USER}@${EC2_IP}"
        REPO_DIR    = '/home/ubuntu/python-project/python-flask-cicd-ec2' // <--- Update the directory where you cloned the GitHub repo
    }

    stages {
            stage('Checkout') {
                steps {
                    echo '========== CHECKOUT =========='
                    git url: 'https://github.com/marcosolano21/python-flask-cicd-ec2.git', branch: 'main'
                }
                post {
                    success {
                        echo 'Checkout completed successfully.'
                    }
    
                    failure {
                        echo 'Checkout failed.'
                    }
                }
        }
        // ==========================================
        // CI Stage
        // Running locally on Jenkins container
        // ==========================================
        
        stage('Preparation for local environment') {
            steps {
                echo 'Installing dependencies'
                // Creating virtual environment on Jenkins container
                sh '''
                    python3 -m venv venv_local
                    . venv_local/bin/activate
                    pwd
                    ls -l
                    pip install -r requirements.txt
                '''
            }
        }

        stage('Code Quality Analysis (Linting)') {
            steps {
                echo 'Running Flake8 to validate syntaxis...'
                sh '''
                    . venv_local/bin/activate
                    # If any error is found, it will fail
                    flake8 app.py --count --select=E9,F63,F7,F82 --show-source --statistics
                '''
            }
        }

        stage('Static Application Security Testing (SAST)') {
            steps {
                echo 'Running bandit to find security vulnerabilities...'
                sh '''
                    . venv_local/bin/activate
                    bandit -r app.py
                '''
            }
        }

        stage('Unit & Integration Testing (Unit Tests)') {
            steps {
                echo 'Running PyTest tests...'
                sh '''
                    . venv_local/bin/activate
                    PYTHONPATH=. pytest test_app.py -v
                '''
            }
        }

        // ==========================================
        // CD stage
        // Only executed if all the previous tests are successfull
        // ==========================================

        stage('Updating changes on EC2') {
            steps {
                echo 'CI successfull. Stating CD stage on EC2...'
                sshagent(credentials: ['ec2-ssh-pem']) { // Here you need to upate your Jenkins credentials for SSH login on EC2 instance
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_SSH} '
                            cd ${REPO_DIR}
                            git pull origin main
                            source venv/bin/activate
                            pip install -r requirements.txt
                        '
                    """
                }
            }
        }

        stage('Deploying on port 8081') {
            steps {
                echo 'Restating process on port 8081...'
                sshagent(credentials: ['ec2-ssh-pem']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_SSH} '
                            fuser -k 8081/tcp || true
                            cd ${REPO_DIR}
                            source venv/bin/activate
                            nohup python3 app.py 8081 > flask_8081.log 2>&1 &
                            sleep 5
                        '
                    """
                }
            }
        }

        stage('Deploying on port 8082') {
            steps {
                echo 'Restating process on port 8081...'
                sshagent(credentials: ['ec2-ssh-pem']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_SSH} '
                            fuser -k 8082/tcp || true
                            cd ${REPO_DIR}/
                            source venv/bin/activate
                            nohup python3 app.py 8082 > flask_8082.log 2>&1 &
                            sleep 5
                        '
                    """
                }
            }
        }
        
        stage('Smoke Test (Producción)') {
            steps {
                echo "Validation nginx load balancer and Flask respond to http://${EC2_IP}..."
                sh """
                    # Here we are making an HTTP request and save the result code (ej: 200, 502, 404)
                    STATUS_CODE=\$(curl -s -o /dev/null -w "%{http_code}" http://${EC2_IP}/)
                    
                    echo "Response: \$STATUS_CODE"
                    
                    if [ "\$STATUS_CODE" -eq 200 ]; then
                        echo "¡Smoke test successfull!"
                    else
                        echo "¡FAILED! Response: \$STATUS_CODE. "
                        exit 1
                    fi
                """
            }
        }
        
        
    }

    post {
        success {
            echo '¡Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed, check errors'
        }
    }
}